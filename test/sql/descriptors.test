# name: test/sql/descriptors.test
# description: SMILES validity, formula, weight, counts, and InChIKey
# group: [vgi_chem]

require-env VGI_CHEM_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'chem' AS chem (TYPE vgi, LOCATION '${VGI_CHEM_WORKER}');

# ---- validity ----

query I
SELECT chem.is_valid_smiles('CCO');
----
true

query I
SELECT chem.is_valid_smiles('xyz');
----
false

# NULL input -> NULL output.
query I
SELECT chem.is_valid_smiles(NULL) IS NULL;
----
true

# ---- formula + weight ----

query I
SELECT chem.mol_formula('CC(=O)OC1=CC=CC=C1C(=O)O');
----
C9H8O4

query I
SELECT ROUND(chem.mol_weight('CC(=O)OC1=CC=CC=C1C(=O)O'), 2);
----
180.16

# Invalid SMILES -> NULL for value functions.
query I
SELECT chem.mol_formula('xyz') IS NULL;
----
true

query I
SELECT chem.mol_weight('xyz') IS NULL;
----
true

# ---- counts ----

query I
SELECT chem.num_atoms('c1ccccc1');
----
6

query I
SELECT chem.num_rings('c1ccccc1');
----
1

query I
SELECT chem.num_h_donors('CCO');
----
1

# ---- InChIKey (exact) ----

query I
SELECT chem.inchikey('CC(=O)OC1=CC=CC=C1C(=O)O');
----
BSYNRYMUTXBXSQ-UHFFFAOYSA-N

# Per-row use over a small VALUES table.
query II rowsort
SELECT s, chem.is_valid_smiles(s)
FROM (VALUES ('CCO'), ('xyz'), ('c1ccccc1')) AS t(s);
----
CCO	true
c1ccccc1	true
xyz	false

statement ok
DETACH chem;
